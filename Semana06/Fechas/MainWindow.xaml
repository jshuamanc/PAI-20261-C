<Window x:Class="Fechas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fechas"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="40,20,40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Margin="0,5,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock TextWrapping="Wrap" Text="Cliente:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <TextBox x:Name="txtCliente" TextWrapping="Wrap" Height="30" Width="250" FontSize="15"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock TextWrapping="Wrap" Text="Monto a pagar: " VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <TextBox x:Name="txtMonto" TextWrapping="Wrap" Width="200" Height="30" VerticalAlignment="Center" FontSize="15"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock TextWrapping="Wrap" Text="Fch. Vencimiento:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <DatePicker x:Name="dpVencimiento" VerticalAlignment="Center" Width="191"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock TextWrapping="Wrap" Text="Fch. Pago:" VerticalAlignment="Center" Margin="0,0,45,0" FontWeight="Bold"/>
                <DatePicker x:Name="dpPago" VerticalAlignment="Center" Width="186"/>

            </StackPanel>

        </Grid>
        <Grid Grid.Row="2" Margin="0,0,0,30" Grid.RowSpan="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,10,0">
                <Button x:Name="btnCalcular" Content="Calcular" Margin="10,0,10,0" Width="60" FontWeight="Bold" Click="btnCalcular_Click"/>
                <Button x:Name="btnNuevo" Content="Nuevo" Margin="10,0,10,0" Width="60" FontWeight="Bold" Click="btnNuevo_Click"/>
                <Button x:Name="btnFinalizar" Content="Finalizar" Margin="10,0,10,0" Width="60" FontWeight="Bold" Click="btnFinalizar_Click"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="3" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="Dias de Mora" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBox x:Name="txtDiasMora" TextWrapping="Wrap" FontSize="15" Height="30" IsEnabled="False" Background="#FFEA670C"/>
            </StackPanel>
            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="Mora en S/." FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="5">
                <TextBox x:Name="txtMoraSoles" TextWrapping="Wrap" FontSize="15" Height="30" IsEnabled="False" Background="#FFEA670C"/>
            </StackPanel>



        </Grid>
        <Grid Grid.Row="4" Margin="0,10,4,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="Mora en %:" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBox x:Name="txtMoraPorc" TextWrapping="Wrap" FontSize="15" Height="30" IsEnabled="False" Background="#FFEA670C"/>
            </StackPanel>
            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="Mnt a pagar:" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="5">
                <TextBox x:Name="txtMontoPagar" TextWrapping="Wrap" FontSize="15" Height="30" IsEnabled="False" Background="#FFEA670C"/>
            </StackPanel>



        </Grid>

    </Grid>
</Window>
