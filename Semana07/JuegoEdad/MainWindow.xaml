<Window x:Class="JuegoEdad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JuegoEdad"
        mc:Ignorable="d"
        Title="Adivina Edad" Height="450" Width="800">
    <Grid Margin="50,30,50,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="Indica al computador un intervalo de edades" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
        <Grid Grid.Row="1" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtMinimo" Grid.Column="0" HorizontalAlignment="Right" TextWrapping="Wrap" VerticalAlignment="Center" Width="120" FontSize="14"/>
            <TextBox x:Name="txtMaximo" Grid.Column="2" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center" Width="120" FontSize="14"/>
        </Grid>
        <TextBox x:Name="txtEdad" Grid.Row="4" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" Width="120" FontSize="14"/>
        <Button x:Name="btnPrimerIntento" Grid.Row="2" Content="Primer Intento" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="3" HorizontalAlignment="Center" TextWrapping="Wrap" Text="La computadora piensa que tu edad es:" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
        <Grid Grid.Row="5" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnCorrecto" Grid.Column="0" Content="Correcto" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <Button x:Name="btnIncorrecto" Grid.Column="2" Content="Incorrecto" HorizontalAlignment="Left" VerticalAlignment="Center"/>
   
        </Grid>
    </Grid>
</Window>
