<Window x:Class="Juego21.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Juego21"
        mc:Ignorable="d"
        Title="Juego 21" Height="700" Width="1200" MinHeight="480" MinWidth="800">
    <Grid Background="#FFF8F8F8" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar with centered New Game button -->
        <DockPanel Grid.Row="0" Margin="0,6">
            <Button x:Name="NewGameButton" Content="Nuevo Juego" Width="110" Height="28" HorizontalAlignment="Center" Margin="0,6" />
        </DockPanel>

        <!-- Main content: two player areas -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Player 1 panel -->
            <Border Grid.Column="0" CornerRadius="8" Background="#266B2B" Padding="14" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="P1ScoreText" Text="Jugador 1  Puntos: 0" FontWeight="Bold" Foreground="White" FontSize="16" />

                    <!-- Cards area: uses an ItemsControl with WrapPanel so images flow responsively -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="Transparent">
                        <ItemsControl x:Name="Player1Cards" HorizontalAlignment="Left">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" Orientation="Horizontal" ItemHeight="120" ItemWidth="80"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Player controls -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="P1_HitButton" Content="Pedir Carta" Width="110" Height="30" Margin="4,0" />
                        <Button x:Name="P1_StandButton" Content="Plantarse" Width="110" Height="30" Margin="4,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Player 2 panel -->
            <Border Grid.Column="1" CornerRadius="8" Background="#266B2B" Padding="14" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="P2ScoreText" Text="Jugador 2  Puntos: 0" FontWeight="Bold" Foreground="White" FontSize="16" HorizontalAlignment="Right" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="Transparent">
                        <ItemsControl x:Name="Player2Cards" HorizontalAlignment="Left">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" Orientation="Horizontal" ItemHeight="120" ItemWidth="80"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="P2_HitButton" Content="Pedir Carta" Width="110" Height="30" Margin="4,0" />
                        <Button x:Name="P2_StandButton" Content="Plantarse" Width="110" Height="30" Margin="4,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom status bar -->
        <Border Grid.Row="2" Background="#FFF9E2B2" CornerRadius="6" BorderBrush="#FFDFC48A" BorderThickness="1" Padding="10" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" Text="Mensaje del juego aparecerá aquí" FontWeight="Bold" Foreground="#333" TextAlignment="Center" />
        </Border>
    </Grid>
</Window>
