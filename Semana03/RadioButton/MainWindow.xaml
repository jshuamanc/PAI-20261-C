<Window x:Class="RadioButton.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RadioButton"
        mc:Ignorable="d"
        Title="Main RadioButton" Height="450" Width="800">
    <Grid>
        <RadioButton x:Name="rbSuma" Content="Suma: +" HorizontalAlignment="Left" Margin="58,147,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbResta" Content="Resta: -" HorizontalAlignment="Left" Margin="58,181,0,0" VerticalAlignment="Top"/>
        <Label Content="Número A:" HorizontalAlignment="Left" Margin="44,36,0,0" VerticalAlignment="Top"/>
        <Label Content="Número B:" HorizontalAlignment="Left" Margin="44,86,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txtNumeroA" HorizontalAlignment="Left" Margin="116,40,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="txtNumeroB" HorizontalAlignment="Left" Margin="116,90,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <RadioButton x:Name="rbMultiplicacion" Content="Multiplicación: *" HorizontalAlignment="Left" Margin="58,217,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbDivision" Content="División: /" HorizontalAlignment="Left" Margin="58,253,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btnCalcular" Content="Calcular" HorizontalAlignment="Left" Margin="58,291,0,0" VerticalAlignment="Top" Click="btnCalcular_Click"/>
        <Label x:Name="lbResultado" Content="Resultado: " HorizontalAlignment="Left" Margin="58,330,0,0" VerticalAlignment="Top" RenderTransformOrigin="-2.15,1.149"/>

    </Grid>
</Window>
