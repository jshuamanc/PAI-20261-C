<Window x:Class="Semana03.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Semana03"
        mc:Ignorable="d"
        Title="Main CheckBox" Height="450" Width="800" WindowState="Maximized">
    <Grid>
        <CheckBox x:Name="cbCebolla" Content="Cebolla (S/. 3)" HorizontalAlignment="Left" Margin="61,46,0,0" VerticalAlignment="Top" IsChecked="False"/>
        <CheckBox x:Name="cbTomate" Content="Tomate (S/ 1.5)" HorizontalAlignment="Left" Margin="61,77,0,0" VerticalAlignment="Top"/>
        <CheckBox x:Name="cbPapa" Content="Papa (S/ 2)" HorizontalAlignment="Left" Margin="61,113,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txtCantidad" HorizontalAlignment="Left" Margin="61,188,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Label Content="Cantidad" HorizontalAlignment="Left" Margin="61,157,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btnCalcular" Content="" HorizontalAlignment="Left" Margin="61,221,0,0" VerticalAlignment="Top" Click="btnCalcular_Click" Height="36" Width="77">
            <Button.Background>
                <ImageBrush ImageSource="/moneda.png"/>
            </Button.Background>
        </Button>
        <Label x:Name="lbTotal" Content="Total S/.: " HorizontalAlignment="Left" Margin="189,231,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
