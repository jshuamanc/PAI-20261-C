<Window x:Class="Semana04.ComboBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Semana04"
        mc:Ignorable="d"
        Title="ComboBox" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="141*"/>
            <RowDefinition Height="293*"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <ComboBox x:Name="cmbFrutas" Width="139">
                <ComboBoxItem Content="Pera"/>
                <ComboBoxItem Content="Piña"/>
                <ComboBoxItem Content="Papaya"/>
                <ComboBoxItem Content="Limon"/>
            </ComboBox>
            <Button x:Name="btnMostrar" Content="Mostrar Seleccionado" Width="140" Margin="0,10,0,0" Click="btnMostrar_Click"/>
        </StackPanel>
        <StackPanel Grid.Row="1">
            <Label Content="Nueva Fruta" HorizontalAlignment="Center"/>
            <TextBox x:Name="txtNuevo" TextWrapping="Wrap" Width="120"/>
            <Button x:Name="btnAgregar" Content="Agregar" Width="118" Margin="0,10,0,0" Click="btnAgregar_Click"/>
        </StackPanel>

    </Grid>
</Window>
