<Window x:Class="Semana04.ListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Semana04"
        mc:Ignorable="d"
        Title="ListView" Height="450" Width="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="37*"/>
            <RowDefinition Height="180*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.ColumnSpan="3" Margin="0,74,0,0" Grid.RowSpan="2">
            <ListView x:Name="lvAlumnos" Height="278" >
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Nombres" Width="250" DisplayMemberBinding="{Binding Nombres}"/>
                        <GridViewColumn Header="Apellidos" Width="250" DisplayMemberBinding="{Binding Apellidos}"/>
                        <GridViewColumn Header="Edad" Width="80" DisplayMemberBinding="{Binding Edad}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>
        <Label Content="Nombre" HorizontalAlignment="Left" Margin="22,10,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txtNombre" HorizontalAlignment="Left" Margin="81,14,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Label Content="Apellidos" HorizontalAlignment="Left" Margin="245,10,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.079,0.208"/>
        <TextBox x:Name="txtApellidos" HorizontalAlignment="Left" Margin="309,14,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Label Content="Edad" HorizontalAlignment="Left" Margin="484,10,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.87,-0.071"/>
        <TextBox x:Name="txtEdad" HorizontalAlignment="Left" Margin="536,14,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Button x:Name="btnAgregar" Content="Agregar Nuevo" HorizontalAlignment="Left" Margin="81,46,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.352,0.127" Click="btnAgregar_Click"/>
        <Button x:Name="btnMostrar" Content="Mostrar Seleccionado" HorizontalAlignment="Left" Margin="634,44,0,0" VerticalAlignment="Top" Click="btnMostrar_Click"/>

    </Grid>
</Window>
