<Window x:Class="Semana04.ListBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Semana04"
        mc:Ignorable="d"
        Title="ListBox" Height="450" Width="800">
    <Grid>
        <TextBlock HorizontalAlignment="Left" Margin="23,17,0,0" TextWrapping="Wrap" Text="Frutas" VerticalAlignment="Top"/>
        <ListBox x:Name="lbFrutas" Margin="23,38,602,293">
            <ListBoxItem Content="Piña"/>
            <ListBoxItem Content="Pera"/>
        </ListBox>
        <Button x:Name="btnMostrar" Content="Mostrar Seleccionado" HorizontalAlignment="Left" Margin="23,156,0,0" VerticalAlignment="Top" RenderTransformOrigin="-1.292,-0.905" Width="175" Click="btnMostrar_Click"/>
        <TextBlock HorizontalAlignment="Left" Margin="23,217,0,0" TextWrapping="Wrap" Text="Nuevo" VerticalAlignment="Top"/>
        <TextBox x:Name="txtNuevo" HorizontalAlignment="Left" Margin="23,238,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="175"/>
        <Button x:Name="btnAgregar" Content="Agregar Item" HorizontalAlignment="Left" Margin="23,269,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.739,0.433" Width="175" Click="btnAgregar_Click"/>
    </Grid>
</Window>
